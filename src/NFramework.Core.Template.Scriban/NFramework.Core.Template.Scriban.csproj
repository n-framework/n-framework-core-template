<Project Sdk="Microsoft.NET.Sdk">
  <!-- Project Configuration -->
  <PropertyGroup>
    <TargetFramework>net11.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>
  <!-- Build Optimization -->
  <PropertyGroup>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <AnalysisLevel>latest</AnalysisLevel>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <Deterministic>true</Deterministic>
    <Optimize>true</Optimize>
  </PropertyGroup>
  <!-- Package Configuration -->
  <PropertyGroup>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <Version>0.1.0</Version>
    <Authors>NFramework</Authors>
    <Product>NFramework</Product>
    <PackageId>NFramework.Core.Template.Scriban</PackageId>
    <Title>NFramework Core Template - Scriban</Title>
    <Description>Scriban-based template engine implementation for NFramework.</Description>
    <PackageTags>template; scriban; codegen; nframework</PackageTags>
    <RepositoryUrl>https://github.com/n-framework/n-framework-core-template</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NFramework.Core.Template.Abstractions\NFramework.Core.Template.Abstractions.csproj" />
    <ProjectReference Include="..\NFramework.Core.Template.Engine\NFramework.Core.Template.Engine.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.5" />
    <PackageReference Include="PluralizeService.Core" Version="2.1.1" />
    <PackageReference Include="Scriban" Version="7.0.3" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NFramework.Core.Template.Scriban.Tests" />
  </ItemGroup>
</Project>
